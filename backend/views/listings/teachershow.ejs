<%layout("layouts/boilerplate.ejs")-%>

<div class="card mb-4 mt-4">
    <div class="row g-0">
        <div class="col-md-4 d-flex align-items-center justify-content-center p-4">
            <div class="text-center">
                <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center" style="width:140px;height:140px;font-size:2.5rem;">
                    <i class="fa-solid fa-chalkboard-user"></i>
                </div>
                <h4 class="mt-3"><%=result[0].TNAME%></h4>
                <p class="text-muted-small mb-0"><i class="fa-solid fa-envelope"></i>&nbsp; <%=result[0].EMAIL%></p>
                <p class="text-muted-small">Specialization: <strong><%=result[0].SPECIAL%></strong></p>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card-body">
                <h5 class="card-title">About</h5>
                <p class="card-text text-muted-small"><%=result[0].BIO%></p>
                <hr>
                <h5>Courses by this teacher</h5>
                <div class="row">
                    <% for(let i=0;i<result.length;i++){ let course = result[i]; %>
                        <div class="col-12 col-md-6 mb-3">
                            <div class="d-flex align-items-start gap-3">
                                <img src="<%=course.IMGLINK%>" alt="" style="width:72px;height:54px;object-fit:cover;border-radius:.4rem;"/>
                                <div>
                                    <div class="fw-semibold"><%=course.TITLE %></div>
                                    <a href="/mindbloom/course/<%=course.CID%>" class="btn btn-sm btn-outline-primary mt-1">View Course</a>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>