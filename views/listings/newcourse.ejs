<%layout("layouts/boilerplate")-%>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <form action="/mindbloom/courses" method="post" novalidate class="needs-validation">
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input type="text" name="title" placeholder="Enter title" id="title" class="form-control" required>
                <div class="valid-feedback">Title looks good!!</div>
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea id="description" name="description" cols="30" rows="10"
                    class="form-control" required></textarea>
                <div class="invalid-feedback">Description should be short and sweet</div>
            </div>
            <div class="mb-3">
                <label for="video" class="form-label">Number of Videos</label>
                <input type="text" name="video" placeholder="Enter number of videos" id="video" class="form-control" required>
                <div class="valid-feedback">Great number of videos!!</div>
            </div>
            <div class="mb-3">
                <label for="tname" class="form-label">Teacher Username</label>
                <input type="text" name="tname" placeholder="Enter teacher username" id="tname" class="form-control" required>
            </div>
            <div class="mb-3">
                <label for="image_url" class="form-label">Cover Image URL</label>
                <input type="text" class="form-control" name="imgLink" placeholder="Enter image url" id="image_url">
            </div>
            <div class="mb-3">
                <label for="video_url" class="form-label">Video URL</label>
                <input type="text" class="form-control" name="vidLink" placeholder="Enter video url" id="video_url">
            </div>
            <div class="mb-3">
                <button class="btn btn-dark edit-btn mt-3">Add</button>
            </div>
        </form>
    </div>
</div>