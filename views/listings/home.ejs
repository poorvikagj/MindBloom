<%layout("layouts/boilerplate")-%>
<% if(currentAdmin) { %>
    <div class="admin-cta card border-0 shadow-sm mb-4">
        <div class="card-body d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div>
                <p class="text-uppercase text-muted-small mb-1">Admin access</p>
                <h3 class="mb-1">Add a new course to MindBloom</h3>
                <p class="mb-0 text-muted">Create a course, assign a teacher, and it will appear on the home page immediately.</p>
            </div>
            <a href="/mindbloom/courses/new" class="btn btn-dark px-4">
                <i class="fa-solid fa-plus me-2"></i>Add Course
            </a>
        </div>
    </div>
<% } %>
    <h3 class="heading">Courses Available</h3>
    <div class="row">
        <%for(let course of result) { 
            const coverImage = course.IMGLINK && course.IMGLINK.trim() ? course.IMGLINK : '/images/course-placeholder.svg';
        %>
            <div class="col-lg-4 col-md-6 mb-4">
                <a href="/mindbloom/course/<%=course.CID%>" class="listing-link">
                    <div class="card h-100">
                        <img src="<%= coverImage %>" class="card-img-top" alt="<%= course.TITLE %> cover image" onerror="this.onerror=null;this.src='/images/course-placeholder.svg';">
                        <div class="card-body">
                            <h5 class="card-title"><%=course.TITLE%></h5>
                            <p class="card-text"><%=course.DESCRIP%></p>
                        </div>
                    </div>
                </a>
            </div>
        <%}%>
    </div>