<%- layout("layouts/boilerplate") -%>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <% if (user.IMG) { %>
                    <img src="<%= user.IMG %>" class="card-img-top " id="pp" alt="Profile Pic" style="height: 200px; object-fit: cover;">
                <% } else { %>
                    <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                        <i class="fas fa-user fa-5x text-white"></i>
                    </div>
                <% } %>
                <br><br>
                <div class="card-body">
                    <h5 class="card-title text-center">
                        <%= user.UNAME %>
                    </h5>
                    <p class="card-text">
                        <strong>Email:</strong> <%= user.EMAIL %>
                    </p>
                    
                    <hr>
                    
                    <h6><strong>Enrolled Courses</strong></h6>
                    <% if (enrolledCourses && enrolledCourses.length > 0) { %>
                        <ul class="list-group list-group-flush">
                            <% for(let course of enrolledCourses) { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong><%= course.TITLE %></strong>
                                        <% if (course.TNAME) { %>
                                            <br><small class="text-muted">by <%= course.TNAME %></small>
                                        <% } %>
                                    </div>
                                    <a href="/mindbloom/course/<%= course.CID %>" class="btn btn-sm btn-primary">View</a>
                                </li>
                            <% } %>
                        </ul>
                    <% } else { %>
                        <p class="text-muted">You haven't enrolled in any courses yet.</p>
                        <a href="/mindbloom" class="btn btn-primary">Browse Courses</a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>